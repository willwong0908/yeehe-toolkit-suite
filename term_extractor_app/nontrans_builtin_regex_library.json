{
  "version": 1,
  "rules": [
    {
      "rule_id": "builtin_html_attr_open",
      "name": "HTML属性开始标签",
      "pattern": "<[A-Za-z][A-Za-z0-9:_-]*(?:\\s*=\\s*(?:\"[^\"<>\\r\\n]*\"|'[^'<> \\r\\n]*'|[^\\s\"'=<>`]+)|(?:\\s+[A-Za-z_:][A-Za-z0-9:._-]*(?:\\s*=\\s*(?:\"[^\"<>\\r\\n]*\"|'[^'<> \\r\\n]*'|[^\\s\"'=<>`]+))?)*)\\s*>",
      "element_type": "html",
      "open_pattern": "<[A-Za-z][A-Za-z0-9:_-]*(?:\\s*=\\s*(?:\"[^\"<>\\r\\n]*\"|'[^'<> \\r\\n]*'|[^\\s\"'=<>`]+)|(?:\\s+[A-Za-z_:][A-Za-z0-9:._-]*(?:\\s*=\\s*(?:\"[^\"<>\\r\\n]*\"|'[^'<> \\r\\n]*'|[^\\s\"'=<>`]+))?)*)\\s*>",
      "close_pattern": "",
      "empty_pattern": "",
      "enabled": true,
      "order_index": 1,
      "examples": [
        "<size=150%>",
        "<div>",
        "<bad_tag>"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "builtin_html_attr_empty",
      "name": "HTML属性自闭合标签",
      "pattern": "<[A-Za-z][A-Za-z0-9:_-]*(?:\\s*=\\s*(?:\"[^\"<>\\r\\n]*\"|'[^'<> \\r\\n]*'|[^\\s\"'=<>`]+)|(?:\\s+[A-Za-z_:][A-Za-z0-9:._-]*(?:\\s*=\\s*(?:\"[^\"<>\\r\\n]*\"|'[^'<> \\r\\n]*'|[^\\s\"'=<>`]+))?)*)\\s*/>",
      "element_type": "html",
      "open_pattern": "",
      "close_pattern": "",
      "empty_pattern": "<[A-Za-z][A-Za-z0-9:_-]*(?:\\s*=\\s*(?:\"[^\"<>\\r\\n]*\"|'[^'<> \\r\\n]*'|[^\\s\"'=<>`]+)|(?:\\s+[A-Za-z_:][A-Za-z0-9:._-]*(?:\\s*=\\s*(?:\"[^\"<>\\r\\n]*\"|'[^'<> \\r\\n]*'|[^\\s\"'=<>`]+))?)*)\\s*/>",
      "enabled": true,
      "order_index": 2,
      "examples": [
        "<player_name color=\"#FF0000\" />",
        "<status_icon type='poison' duration=5 />",
        "<buff_add val=\"+15%\" />"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "builtin_html_close",
      "name": "HTML闭合标签",
      "pattern": "</[A-Za-z][A-Za-z0-9:_-]*\\s*>",
      "element_type": "html",
      "open_pattern": "",
      "close_pattern": "</[A-Za-z][A-Za-z0-9:_-]*\\s*>",
      "empty_pattern": "",
      "enabled": true,
      "order_index": 3,
      "examples": [
        "</b>",
        "</size>",
        "</div>"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "builtin_hash_brace",
      "name": "#花括号变量",
      "pattern": "#\\{(?:\\d+|[A-Za-z_][A-Za-z0-9_.\\[\\]-]*)(?::[A-Za-z0-9_.,#%+\\-]+)?\\}",
      "element_type": "hash_brace",
      "open_pattern": "",
      "close_pattern": "",
      "empty_pattern": "#\\{(?:\\d+|[A-Za-z_][A-Za-z0-9_.\\[\\]-]*)(?::[A-Za-z0-9_.,#%+\\-]+)?\\}",
      "enabled": true,
      "order_index": 4,
      "examples": [
        "#{positive}",
        "#{negative}",
        "#{warning}"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "builtin_brace",
      "name": "花括号占位符",
      "pattern": "\\{(?:\\d+|[A-Za-z_][A-Za-z0-9_.\\[\\]-]*)(?::[A-Za-z0-9_.,#%+\\-]+)?\\}",
      "element_type": "brace",
      "open_pattern": "",
      "close_pattern": "",
      "empty_pattern": "\\{(?:\\d+|[A-Za-z_][A-Za-z0-9_.\\[\\]-]*)(?::[A-Za-z0-9_.,#%+\\-]+)?\\}",
      "enabled": true,
      "order_index": 5,
      "examples": [
        "{net_ping}",
        "{guild.name}",
        "{guild.id}"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "builtin_bracket",
      "name": "方括号标签",
      "pattern": "\\[(?:/?[A-Za-z_#][A-Za-z0-9_#|:.+\\-]*|[A-Za-z_#][A-Za-z0-9_#|:.+\\-]*=[A-Za-z0-9_#|:.+\\-]+)\\]",
      "element_type": "bracket",
      "open_pattern": "",
      "close_pattern": "",
      "empty_pattern": "\\[(?:/?[A-Za-z_#][A-Za-z0-9_#|:.+\\-]*|[A-Za-z_#][A-Za-z0-9_#|:.+\\-]*=[A-Za-z0-9_#|:.+\\-]+)\\]",
      "enabled": true,
      "order_index": 6,
      "examples": [
        "[sprite=icon_coin]",
        "[BTN_A]"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "builtin_dollar_var",
      "name": "$变量",
      "pattern": "\\$(?:\\{(?:\\d+|[A-Za-z_][A-Za-z0-9_.\\[\\]-]*)(?::[A-Za-z0-9_.,#%+\\-]+)?\\}|\\([^\\s()<>[\\]{}]+\\)|\\[[^\\s\\[\\]<>({})]+\\]|<[^\\s<>]+>|[A-Za-z_][A-Za-z0-9_]*(?:\\[\\d+\\])*)",
      "element_type": "dollar_var",
      "open_pattern": "",
      "close_pattern": "",
      "empty_pattern": "\\$(?:\\{(?:\\d+|[A-Za-z_][A-Za-z0-9_.\\[\\]-]*)(?::[A-Za-z0-9_.,#%+\\-]+)?\\}|\\([^\\s()<>[\\]{}]+\\)|\\[[^\\s\\[\\]<>({})]+\\]|<[^\\s<>]+>|[A-Za-z_][A-Za-z0-9_]*(?:\\[\\d+\\])*)",
      "enabled": true,
      "order_index": 7,
      "examples": [
        "${interestAmount}",
        "${value}",
        "${net_ping}"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "builtin_at_var",
      "name": "@变量",
      "pattern": "@[A-Za-z_][A-Za-z0-9_]*",
      "element_type": "at_var",
      "open_pattern": "",
      "close_pattern": "",
      "empty_pattern": "@[A-Za-z_][A-Za-z0-9_]*",
      "enabled": true,
      "order_index": 8,
      "examples": [
        "@PlayerName"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "builtin_percent_var",
      "name": "%变量",
      "pattern": "%(?:[A-Za-z_][A-Za-z0-9_]*%|(?:\\d+\\$)?[#0\\- +']*(?:\\d+)?(?:\\.\\d+)?[A-Za-z])",
      "element_type": "percent_var",
      "open_pattern": "",
      "close_pattern": "",
      "empty_pattern": "%(?:[A-Za-z_][A-Za-z0-9_]*%|(?:\\d+\\$)?[#0\\- +']*(?:\\d+)?(?:\\.\\d+)?[A-Za-z])",
      "enabled": true,
      "order_index": 9,
      "examples": [
        "%s",
        "%PlayerName%"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "builtin_escape",
      "name": "转义符",
      "pattern": "\\\\(?:[nrtbfav\\\\'\\\"0]|u[0-9A-Fa-f]{4}|x[0-9A-Fa-f]{2})",
      "element_type": "escape",
      "open_pattern": "",
      "close_pattern": "",
      "empty_pattern": "\\\\(?:[nrtbfav\\\\'\\\"0]|u[0-9A-Fa-f]{4}|x[0-9A-Fa-f]{2})",
      "enabled": true,
      "order_index": 10,
      "examples": [
        "\\n",
        "\\u3000"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "builtin_html_entity",
      "name": "HTML实体",
      "pattern": "&(?:[A-Za-z][A-Za-z0-9]{1,31}|#\\d{1,7}|#x[0-9A-Fa-f]{1,6});",
      "element_type": "html_entity",
      "open_pattern": "",
      "close_pattern": "",
      "empty_pattern": "&(?:[A-Za-z][A-Za-z0-9]{1,31}|#\\d{1,7}|#x[0-9A-Fa-f]{1,6});",
      "enabled": true,
      "order_index": 11,
      "examples": [
        "&nbsp;",
        "&#160;"
      ],
      "source": "builtin",
      "conflict_notes": ""
    },
    {
      "rule_id": "ai_1_filter_warning",
      "name": "brace_warning_family",
      "pattern": "\\{[A-Za-z_][A-Za-z0-9_]*\\|Warning\\}",
      "element_type": "brace",
      "open_pattern": "",
      "close_pattern": "",
      "empty_pattern": "\\{[A-Za-z_][A-Za-z0-9_]*\\|Warning\\}",
      "enabled": true,
      "order_index": 12,
      "examples": [
        "{filter|Warning}",
        "{base|Warning}",
        "{chargesleft|Warning}"
      ],
      "source": "builtin",
      "conflict_notes": ""
    }
  ]
}